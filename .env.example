# App
APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth.js
# Local: keep AUTH_URL aligned with the dev server URL.
# Vercel production/preview: set AUTH_URL to the public deployment URL,
# or remove AUTH_URL and keep AUTH_TRUST_HOST="true" so Auth.js uses the request host.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
AUTH_SECRET=""
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="Alchimiste Créations <contact@example.com>"
AUTH_EMAIL_LOGO_URL="https://alchimiste-creations.fr/images/brand/logo-primary.png"
AUTH_ADMIN_EMAILS="admin@example.com"

# Email
RESEND_API_KEY=""
PROJECT_REQUEST_EMAIL_FROM="Alchimiste Créations <contact@example.com>"
PROJECT_REQUEST_EMAIL_TO="contact@example.com"
CONTACT_EMAIL_FROM="Alchimiste Créations <contact@example.com>"
CONTACT_EMAIL_TO="contact@example.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Acquisition
# Lien "laisser un avis" envoyé au client à la clôture du projet
# (fiche Google Business Profile). Optionnel : sans lui, l'e-mail de
# clôture renvoie vers l'espace client.
GOOGLE_REVIEW_URL=""
